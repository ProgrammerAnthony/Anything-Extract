# AnythingExtract Docker 部署环境变量模板
# 复制为 .env.docker 后按需修改
# 使用方式：docker_run.sh 会自动读取 .env.docker

# ============================================================
# Ollama 配置
# - Windows/macOS（宿主机 Ollama）：http://host.docker.internal:11434
# - Linux（宿主机 Ollama）：        http://localhost:11434
# - Ollama 容器化（--with-ollama）： http://ollama:11434（Win/Mac）
# ============================================================
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ============================================================
# 应用配置
# ============================================================
API_HOST=0.0.0.0
API_PORT=8888
FRONTEND_URL=http://localhost:3001
INGEST_DEFAULT_MODE=queue

# ============================================================
# QAnything OCR/PDF 服务（使用 --with-models 时自动配置）
# parser_mode: local | hybrid
#   local  = 只用本地解析（不依赖 QAnything 服务）
#   hybrid = 优先调用外部服务，失败回退本地
# ============================================================
ENABLE_OCR_SERVER=false
ENABLE_PDF_PARSER_SERVER=false
PARSER_MODE=local
# OCR_SERVER_URL 和 PDF_PARSER_SERVER_URL 在 compose 文件中已按平台设置好

# ============================================================
# 说明：OCR/PDF 服务代码已内置于 dependent_server/，
#       ML 模型由 xixihahaliu01/qanything-{platform} 镜像提供，
#       无需配置任何 QAnything 外部目录。
# ============================================================
